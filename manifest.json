{
  "manifest_version": 3,
  "name": "Spoiler Shield",
  "description": "Hide spoilers across the web in real time.",
  "version": "0.0.1",
  "action": {
    "default_popup": "src/popup/index.html",
    "default_title": "Spoiler Shield"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/content/index.ts"],
      "run_at": "document_start"
    }
  ],
  "permissions": ["storage"],
  "host_permissions": [
  "https://generativelanguage.googleapis.com/*"
  ]
}