{
  "manifest_version": 3,
  "name": "Spoiler Shield",
  "version": "1.0.0",
  "description": "Blur spoilers about shows, sports, and movies on any website — with AI-assisted keyword expansion.",
  "homepage_url": "https://github.com/Gautham176/spoiler-shield",
  "action": {
    "default_popup": "src/popup/index.html",
    "default_title": "Spoiler Shield"
  },
  "permissions": ["storage", "activeTab"],
  "host_permissions": ["https://generativelanguage.googleapis.com/*"],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/content/index.ts"],
      "run_at": "document_start"
    }
  ]
}