{
  "manifest_version": 3,
  "name": "Spoiler Shield",
  "description": "Chrome extension that hides spoilers across the web in real time",
  "version": "0.0.1",
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/content/index.ts"],
      "run_at": "document_start"
    }
  ],
  "permissions": ["storage"]
}